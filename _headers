  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://accounts.google.com https://challenges.cloudflare.com https://checkout.razorpay.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: blob: https://*.googleusercontent.com https://*.razorpay.com; font-src 'self' data:; connect-src 'self' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://accounts.google.com https://challenges.cloudflare.com https://api.razorpay.com https://lumberjack.razorpay.com https://tessdata.projectnaptha.com; frame-src https://accounts.google.com https://challenges.cloudflare.com https://api.razorpay.com https://checkout.razorpay.com; worker-src 'self' blob: https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; media-src 'self' blob:; form-action 'self' https://checkout.razorpay.com; upgrade-insecure-requests

/api/*
